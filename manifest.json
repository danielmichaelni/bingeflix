{
  "manifest_version": 3,
  "name": "Bingeflix - Binge Netflix Better",
  "version": "1.0.7",

  "description": "Take your Netflix binge to the next level",
  "icons": {
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["binge.js"]
    }
  ],
  "permissions": ["storage"]
}
